# ── Anchor Studio Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.

# Anthropic API key — get yours at https://console.anthropic.com
# This replaces the Cloudflare Worker — Next.js API routes keep this server-side
ANTHROPIC_API_KEY=sk-ant-your-key-here

# API key for chess-club-hub integration — used in /api/generate Authorization header
GENERATE_API_KEY=your-secret-api-key-here

# Your site URL (used for CORS and metadata)
NEXT_PUBLIC_SITE_URL=https://www.getanchorstudio.com

# Calendly booking link — replace with your actual link
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link-here
